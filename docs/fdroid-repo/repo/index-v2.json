{"repo": {"name": {"en-US": "Aether F-Droid Repo"}, "description": {"en-US": "Personal F-Droid repo for Aether, a generative ambient soundscape player. AI co-authored (see the app's own description and the project README)."}, "icon": {"en-US": {"name": "/icons/icon.png", "sha256": "d4d80ca0306a775aad3f8812b97594e6c8b61e5dbd0a0fcc73adfdd1b88ffdc9", "size": 73673}}, "address": "https://thomasehardt.github.io/aether/fdroid-repo/repo", "timestamp": 1783489782000, "categories": {"Multimedia": {"name": {"en-US": "Multimedia"}}}}, "packages": {"net.ehardt.aether": {"metadata": {"added": 1783488159000, "categories": ["Multimedia"], "changelog": "https://github.com/thomasehardt/aether/commits/main", "issueTracker": "https://github.com/thomasehardt/aether/issues", "lastUpdated": 1783489779000, "license": "MIT", "sourceCode": "https://github.com/thomasehardt/aether", "webSite": "https://github.com/thomasehardt/aether", "authorName": "Thomas Ehardt", "name": {"en-US": "Aether"}, "summary": {"en-US": "AI-co-authored generative ambient soundscape player"}, "description": {"en-US": "This app was co-authored by an AI agent (Claude, by Anthropic), directed\nand reviewed by a human. See the project's source repository and git\nhistory for the full record of what was generated versus human-directed.\n\nAether is a generative ambient soundscape player. Every sound — drones, a\nchoir pad, sub bass, rain, ocean waves, wind, generative bell tones, a\nplucked-string arpeggiator, and high shimmer overtones — is synthesized\nlive with the Web Audio API. No audio samples, no loops.\n\nFeatures:\n\n* Nine independently-mixed ambient layers\n* Five root keys, with the melodic layers generated over a shared,\n  slowly-drifting tonal center so they read as one coherent voice\n* Five built-in presets\n* Reactive audio-driven visualizer\n* Fully offline — no network access, no accounts, no tracking\n"}, "icon": {"en-US": {"name": "/icons/net.ehardt.aether.3000.png", "sha256": "5f07229cc58f9176397b97643b35601bb8fc0d91561c4b7db7a14498cf0b4ec4", "size": 3027}}, "preferredSigner": "67970d5f4502acaeb4c093171df61e20642865f67d305b180284002fa494ae6c"}, "versions": {"c67b131d834a31319452cb3838a52c44ff445a56171d79de077e3754815382be": {"added": 1783489779000, "file": {"name": "/net.ehardt.aether_3000.apk", "sha256": "c67b131d834a31319452cb3838a52c44ff445a56171d79de077e3754815382be", "size": 3716780}, "manifest": {"versionName": "0.3.0", "versionCode": 3000, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["67970d5f4502acaeb4c093171df61e20642865f67d305b180284002fa494ae6c"]}, "usesPermission": [{"name": "android.permission.FOREGROUND_SERVICE"}, {"name": "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"}, {"name": "android.permission.POST_NOTIFICATIONS"}, {"name": "net.ehardt.aether.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "349a1a1d9753edad1a2a954027c0188dd55c2a9c04ba651b66628b547aa6accb": {"added": 1783488159000, "file": {"name": "/net.ehardt.aether_2000.apk", "sha256": "349a1a1d9753edad1a2a954027c0188dd55c2a9c04ba651b66628b547aa6accb", "size": 3715628}, "manifest": {"versionName": "0.2.0", "versionCode": 2000, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["67970d5f4502acaeb4c093171df61e20642865f67d305b180284002fa494ae6c"]}, "usesPermission": [{"name": "net.ehardt.aether.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}}}}}